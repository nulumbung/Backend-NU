APP_NAME=Nulumbung
APP_ENV=production
APP_KEY=base64:[YOUR_APP_KEY]
APP_DEBUG=false
APP_URL=https://api.nulumbung.or.id

FRONTEND_URL=https://nulumbung.or.id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=[YOUR_DB_HOST]
DB_PORT=3306
DB_DATABASE=nulumbung
DB_USERNAME=[YOUR_DB_USER]
DB_PASSWORD=[YOUR_DB_PASSWORD]

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.nulumbung.or.id

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=nulumbung_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=[YOUR_REDIS_HOST]
REDIS_PASSWORD=[YOUR_REDIS_PASSWORD]
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=[YOUR_EMAIL@gmail.com]
MAIL_PASSWORD=[YOUR_APP_PASSWORD]
MAIL_FROM_ADDRESS="noreply@nulumbung.or.id"
MAIL_FROM_NAME="Nulumbung"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

GOOGLE_CLIENT_ID=156917081366-ki9cttu9j7ble6psido2rumtov45taoh.apps.googleusercontent.com

